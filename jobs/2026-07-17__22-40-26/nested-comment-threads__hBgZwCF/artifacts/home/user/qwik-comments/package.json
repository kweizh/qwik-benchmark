{
  "name": "qwik-comments",
  "private": true,
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "build": "qwik build",
    "build.client": "vite build",
    "build.server": "vite build -c adapters/node-server/vite.config.ts",
    "dev": "vite --mode ssr --host 0.0.0.0 --port 3000",
    "preview": "qwik build preview && vite preview --open",
    "qwik": "qwik",
    "start": "vite --open --mode ssr"
  },
  "dependencies": {
    "@builder.io/qwik": "1.5.7",
    "@builder.io/qwik-city": "1.5.7",
    "better-sqlite3": "11.3.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.11",
    "@types/node": "20.14.11",
    "typescript": "5.5.4",
    "undici": "*",
    "vite": "5.4.2",
    "vite-tsconfig-paths": "4.3.2"
  },
  "engines": {
    "node": ">=18.17.0"
  }
}